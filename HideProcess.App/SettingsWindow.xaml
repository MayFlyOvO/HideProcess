<Window x:Class="HideProcess.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Width="700"
        Height="560"
        MinWidth="680"
        MinHeight="540"
        WindowStyle="None"
        Icon="pack://application:,,,/Assets/HideProcess.ico"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#FFF6F8FB"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        FontFamily="Segoe UI Variable Text">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="0"
                            CornerRadius="16"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#00FFFFFF" />
            <Setter Property="BorderBrush" Value="#00FFFFFF" />
            <Setter Property="Foreground" Value="#4B5563" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="8"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFEFF2F6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NeutralButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="BorderBrush" Value="#FFE4E7EB" />
            <Setter Property="Background" Value="#FFFFFFFF" />
            <Setter Property="Foreground" Value="#25313D" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="10"
                                BorderThickness="1"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFF7F8FA" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource NeutralButtonStyle}">
            <Setter Property="Background" Value="#FF0A84FF" />
            <Setter Property="BorderBrush" Value="#FF0A84FF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="10"
                                BorderThickness="1"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FF0077EE" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#FF0077EE" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FlatLabeledCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#3D4A56" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border x:Name="Box"
                                    Width="18"
                                    Height="18"
                                    CornerRadius="5"
                                    BorderThickness="1.5"
                                    BorderBrush="#FFB8C2CE"
                                    Background="#FFFFFFFF"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center" />

                            <Path x:Name="CheckMark"
                                  Width="10"
                                  Height="8"
                                  Data="M 0.8 4.2 L 3.8 7.2 L 9.2 1.0"
                                  Stretch="Fill"
                                  Stroke="White"
                                  StrokeThickness="2.2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Visibility="Collapsed"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center" />

                            <ContentPresenter Grid.Column="1"
                                              Margin="8,0,0,0"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="#FF0A84FF" />
                                <Setter TargetName="Box" Property="BorderBrush" Value="#FF0A84FF" />
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#FF7AA8FF" />
                                <Setter TargetName="Box" Property="Background" Value="#FFF6FAFF" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Box" Property="Background" Value="#FF0077EE" />
                                <Setter TargetName="Box" Property="BorderBrush" Value="#FF0077EE" />
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Foreground" Value="#25313D" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                CornerRadius="7"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#FFEFF4FB" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#FFE7F0FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#FFFFFFFF" />
            <Setter Property="BorderBrush" Value="#FFE4E7EB" />
            <Setter Property="Foreground" Value="#25313D" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="12,0,34,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    CornerRadius="10"
                                    BorderThickness="1"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}">
                                <Grid>
                                    <ContentPresenter Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" />
                                    <TextBlock Text="&#xE70D;"
                                               FontFamily="Segoe Fluent Icons"
                                               FontSize="10"
                                               Foreground="#667385"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"
                                               Margin="0,0,12,0" />
                                </Grid>
                            </Border>

                            <ToggleButton x:Name="DropDownToggle"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          ClickMode="Press"
                                          Background="Transparent"
                                          BorderBrush="Transparent">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" />
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   PopupAnimation="Slide">
                                <Border Margin="0,4,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        CornerRadius="10"
                                        Background="White"
                                        BorderThickness="1"
                                        BorderBrush="#FFE4E7EB">
                                    <ScrollViewer MaxHeight="220">
                                        <StackPanel IsItemsHost="True" Margin="4" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="Background" Value="#FFF9FAFC" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#FF7AA8FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#FFF6F8FB">
        <Border Margin="0"
                CornerRadius="16"
                Background="White"
                BorderThickness="0"
                BorderBrush="#00FFFFFF"
                ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="46" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      Background="#FFF7F8FA"
                      MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="14,0,0,0">
                        <Image Width="28"
                               Height="28"
                               Source="pack://application:,,,/Assets/HideProcess.ico"
                               VerticalAlignment="Center"
                               SnapsToDevicePixels="True" />
                        <TextBlock x:Name="HeaderTextBlock"
                                   Margin="8,0,0,0"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#1F2937"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Margin="0,0,8,0"
                            Click="CloseButton_OnClick">
                        <TextBlock Text="&#xE8BB;"
                                   FontFamily="Segoe Fluent Icons"
                                   FontSize="10" />
                    </Button>
                </Grid>

                <StackPanel Grid.Row="1" Margin="16,14,16,0">
                    <Border Margin="0,0,0,14"
                            Padding="16"
                            CornerRadius="12"
                            Background="#FFFAFBFD"
                            BorderThickness="1"
                            BorderBrush="#FFE9EDF3">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="130" />
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="HotkeysSectionTextBlock"
                                       Grid.ColumnSpan="3"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#334155" />

                            <TextBlock x:Name="HideHotkeyLabel"
                                       Grid.Row="1"
                                       Margin="0,14,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       Foreground="#4A5560" />
                            <Border Grid.Row="1"
                                    Grid.Column="1"
                                    Margin="0,14,12,0"
                                    Padding="10,8"
                                    CornerRadius="8"
                                    Background="#FFFFFFFF"
                                    BorderThickness="1"
                                    BorderBrush="#FFE4E7EB">
                                <TextBlock x:Name="HideHotkeyValueTextBlock"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#1F2933" />
                            </Border>
                            <Button x:Name="SetHideHotkeyButton"
                                    Grid.Row="1"
                                    Grid.Column="2"
                                    Margin="0,14,0,0"
                                    Style="{StaticResource NeutralButtonStyle}"
                                    Click="SetHideHotkeyButton_OnClick">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE70F;"
                                               FontFamily="Segoe Fluent Icons"
                                               FontSize="12"
                                               VerticalAlignment="Center" />
                                    <TextBlock x:Name="SetHideHotkeyButtonTextBlock"
                                               Margin="6,0,0,0"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <TextBlock x:Name="ShowHotkeyLabel"
                                       Grid.Row="2"
                                       Margin="0,12,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       Foreground="#4A5560" />
                            <Border Grid.Row="2"
                                    Grid.Column="1"
                                    Margin="0,12,12,0"
                                    Padding="10,8"
                                    CornerRadius="8"
                                    Background="#FFFFFFFF"
                                    BorderThickness="1"
                                    BorderBrush="#FFE4E7EB">
                                <TextBlock x:Name="ShowHotkeyValueTextBlock"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#1F2933" />
                            </Border>
                            <Button x:Name="SetShowHotkeyButton"
                                    Grid.Row="2"
                                    Grid.Column="2"
                                    Margin="0,12,0,0"
                                    Style="{StaticResource NeutralButtonStyle}"
                                    Click="SetShowHotkeyButton_OnClick">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE70F;"
                                               FontFamily="Segoe Fluent Icons"
                                               FontSize="12"
                                               VerticalAlignment="Center" />
                                    <TextBlock x:Name="SetShowHotkeyButtonTextBlock"
                                               Margin="6,0,0,0"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <TextBlock x:Name="HotkeyConflictTextBlock"
                                       Grid.Row="3"
                                       Grid.ColumnSpan="3"
                                       Margin="0,12,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="#C2410C"
                                       FontSize="12"
                                       Visibility="Collapsed" />
                        </Grid>
                    </Border>

                    <Border Padding="16"
                            CornerRadius="12"
                            Background="#FFFAFBFD"
                            BorderThickness="1"
                            BorderBrush="#FFE9EDF3">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="GeneralSectionTextBlock"
                                       Grid.ColumnSpan="2"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#334155" />

                            <CheckBox x:Name="StartWithWindowsCheckBox"
                                      Grid.Row="1"
                                      Grid.ColumnSpan="2"
                                      Margin="0,14,0,0"
                                      Style="{StaticResource FlatLabeledCheckBoxStyle}" />

                            <CheckBox x:Name="MinimizeToTrayCheckBox"
                                      Grid.Row="2"
                                      Grid.ColumnSpan="2"
                                      Margin="0,10,0,0"
                                      Style="{StaticResource FlatLabeledCheckBoxStyle}" />

                            <StackPanel Grid.Row="3"
                                        Grid.ColumnSpan="2"
                                        Orientation="Horizontal"
                                        Margin="0,10,0,0">
                                <CheckBox x:Name="AutoCheckUpdatesCheckBox"
                                          Style="{StaticResource FlatLabeledCheckBoxStyle}" />
                                <Button x:Name="CheckUpdatesButton"
                                        Width="92"
                                        Height="30"
                                        Margin="10,0,0,0"
                                        Padding="10,6"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource NeutralButtonStyle}"
                                        Click="CheckUpdatesButton_OnClick">
                                    <TextBlock x:Name="CheckUpdatesButtonTextBlock"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </Button>
                            </StackPanel>

                            <TextBlock x:Name="LanguageLabel"
                                       Grid.Row="4"
                                       VerticalAlignment="Center"
                                       Margin="0,16,0,0"
                                       FontSize="13"
                                       Foreground="#4A5560" />
                            <ComboBox x:Name="LanguageComboBox"
                                      Grid.Row="4"
                                      Grid.Column="1"
                                      Margin="0,16,0,0"
                                      Height="40"
                                      Style="{StaticResource RoundedComboBoxStyle}"
                                      ItemContainerStyle="{StaticResource RoundedComboBoxItemStyle}"
                                      VerticalContentAlignment="Center"
                                      DisplayMemberPath="DisplayName"
                                      SelectionChanged="LanguageComboBox_OnSelectionChanged" />
                        </Grid>
                    </Border>
                </StackPanel>

                <Grid Grid.Row="2" Margin="16,14,16,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button x:Name="ImportButton"
                                Width="130"
                                Height="40"
                                Margin="0,0,10,0"
                                Style="{StaticResource NeutralButtonStyle}"
                                Click="ImportButton_OnClick">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE898;"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="12"
                                           VerticalAlignment="Center" />
                                <TextBlock x:Name="ImportButtonTextBlock"
                                           Margin="6,0,0,0"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="ExportButton"
                                Width="130"
                                Height="40"
                                Style="{StaticResource NeutralButtonStyle}"
                                Click="ExportButton_OnClick">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE896;"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="12"
                                           VerticalAlignment="Center" />
                                <TextBlock x:Name="ExportButtonTextBlock"
                                           Margin="6,0,0,0"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button x:Name="CancelButton"
                                Width="130"
                                Height="40"
                                Margin="0,0,10,0"
                                Style="{StaticResource NeutralButtonStyle}"
                                Click="CancelButton_OnClick">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE711;"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="12"
                                           VerticalAlignment="Center" />
                                <TextBlock x:Name="CancelButtonTextBlock"
                                           Margin="6,0,0,0"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="SaveButton"
                                Width="130"
                                Height="40"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="SaveButton_OnClick">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE74E;"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="12"
                                           VerticalAlignment="Center" />
                                <TextBlock x:Name="SaveButtonTextBlock"
                                           Margin="6,0,0,0"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
