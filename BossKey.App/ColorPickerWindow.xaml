<Window x:Class="BossKey.App.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Width="372"
        Height="404"
        MinWidth="372"
        MinHeight="404"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Theme.WindowBackgroundBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        FontFamily="Segoe UI Variable Text">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="0"
                            CornerRadius="16"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <FontFamily x:Key="MaterialIconFontFamily">pack://application:,,,/Assets/Fonts/#Material Icons Round</FontFamily>

        <LinearGradientBrush x:Key="HueSpectrumBrush" StartPoint="0,0.5" EndPoint="1,0.5">
            <GradientStop Offset="0" Color="#FFFF004D" />
            <GradientStop Offset="0.17" Color="#FFFFC300" />
            <GradientStop Offset="0.33" Color="#FF37D73F" />
            <GradientStop Offset="0.5" Color="#FF17C1E8" />
            <GradientStop Offset="0.67" Color="#FF1C63FF" />
            <GradientStop Offset="0.83" Color="#FFD916D6" />
            <GradientStop Offset="1" Color="#FFFF004D" />
        </LinearGradientBrush>

        <DrawingBrush x:Key="CheckerboardBrush"
                      TileMode="Tile"
                      Viewport="0,0,12,12"
                      ViewportUnits="Absolute"
                      Viewbox="0,0,12,12"
                      ViewboxUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="{DynamicResource Theme.SurfaceBackgroundBrush}" Geometry="M0,0 H12 V12 H0 Z" />
                    <GeometryDrawing Brush="{DynamicResource Theme.SubtleBackgroundStrongBrush}" Geometry="M0,0 H6 V6 H0 Z M6,6 H12 V12 H6 Z" />
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.IconBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" CornerRadius="8" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Theme.ButtonNeutralHoverBackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NeutralButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="88" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.ButtonNeutralBorderBrush}" />
            <Setter Property="Background" Value="{DynamicResource Theme.ButtonNeutralBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.ButtonNeutralForegroundBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="11"
                                BorderThickness="1"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Theme.ButtonNeutralHoverBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource NeutralButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource Theme.ButtonPrimaryBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.ButtonPrimaryBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.ButtonPrimaryForegroundBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="11"
                                BorderThickness="1"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Theme.ButtonPrimaryHoverBackgroundBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Theme.ButtonPrimaryHoverBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PresetSwatchButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource Theme.WindowBackgroundBrush}">
        <Border Margin="0"
                CornerRadius="16"
                Background="{DynamicResource Theme.SurfaceBackgroundBrush}"
                BorderThickness="0"
                BorderBrush="Transparent"
                ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="{DynamicResource Theme.ChromeBackgroundBrush}" MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                        <Border Width="24"
                                Height="24"
                                CornerRadius="9"
                                Background="{DynamicResource Theme.SubtleBackgroundStrongBrush}"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource Theme.BorderSoftBrush}">
                            <Grid>
                                <Border Width="8"
                                        Height="8"
                                        Margin="0,0,5,5"
                                        CornerRadius="4"
                                        Background="{DynamicResource Theme.ButtonPrimaryBackgroundBrush}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                                <Border Width="8"
                                        Height="8"
                                        Margin="5,0,0,5"
                                        CornerRadius="4"
                                        Background="{DynamicResource Theme.ButtonSuccessBackgroundBrush}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                                <Border Width="8"
                                        Height="8"
                                        Margin="0,6,0,0"
                                        CornerRadius="4"
                                        Background="{DynamicResource Theme.WarningBrush}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <TextBlock x:Name="HeaderTextBlock"
                                   Margin="7,0,0,0"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Theme.PrimaryTextBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <Button Grid.Column="1" Margin="0,0,6,0" Style="{StaticResource TitleBarButtonStyle}" Click="CloseButton_OnClick">
                        <TextBlock Text="&#xE5CD;" FontFamily="{StaticResource MaterialIconFontFamily}" FontSize="14" />
                    </Button>
                </Grid>

                <StackPanel Grid.Row="1" Margin="12,10,12,6">
                    <Border CornerRadius="16"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource Theme.BorderStrongBrush}"
                            Background="{DynamicResource Theme.PanelBackgroundBrush}">
                        <Grid x:Name="ColorFieldHost"
                              Height="112"
                              ClipToBounds="True"
                              MouseLeftButtonDown="ColorFieldHost_OnMouseLeftButtonDown"
                              MouseMove="ColorFieldHost_OnMouseMove"
                              MouseLeftButtonUp="PointerSurface_OnMouseLeftButtonUp"
                              LostMouseCapture="PointerSurface_OnLostMouseCapture"
                              SizeChanged="InteractiveSurface_OnSizeChanged">
                            <Rectangle x:Name="ColorFieldHueLayer" RadiusX="16" RadiusY="16" />
                            <Rectangle RadiusX="16" RadiusY="16">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                        <GradientStop Offset="0" Color="#FFFFFFFF" />
                                        <GradientStop Offset="1" Color="#00FFFFFF" />
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Rectangle RadiusX="16" RadiusY="16">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                        <GradientStop Offset="0" Color="#00FFFFFF" />
                                        <GradientStop Offset="1" Color="#FF000000" />
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Canvas IsHitTestVisible="False">
                                <Ellipse x:Name="ColorFieldSelector"
                                         Width="18"
                                         Height="18"
                                         Stroke="White"
                                         StrokeThickness="2"
                                         Fill="#00FFFFFF">
                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="6"
                                                          ShadowDepth="1"
                                                          Opacity="0.22"
                                                          Color="#FF000000" />
                                    </Ellipse.Effect>
                                </Ellipse>
                            </Canvas>
                        </Grid>
                    </Border>

                    <Grid x:Name="HueSliderHost"
                          Height="12"
                          Margin="0,8,0,0"
                          MouseLeftButtonDown="HueSliderHost_OnMouseLeftButtonDown"
                          MouseMove="HueSliderHost_OnMouseMove"
                          MouseLeftButtonUp="PointerSurface_OnMouseLeftButtonUp"
                          LostMouseCapture="PointerSurface_OnLostMouseCapture"
                          SizeChanged="InteractiveSurface_OnSizeChanged">
                        <Border CornerRadius="6" Background="{StaticResource HueSpectrumBrush}" />
                        <Canvas IsHitTestVisible="False">
                            <Ellipse x:Name="HueSelector"
                                     Width="18"
                                     Height="18"
                                     Stroke="White"
                                     StrokeThickness="2.5"
                                     Fill="{DynamicResource Theme.SurfaceBackgroundBrush}">
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="6"
                                                      ShadowDepth="1"
                                                      Opacity="0.2"
                                                      Color="#FF000000" />
                                </Ellipse.Effect>
                            </Ellipse>
                        </Canvas>
                    </Grid>

                    <Grid x:Name="AlphaSliderHost"
                          Height="12"
                          Margin="0,6,0,0"
                          MouseLeftButtonDown="AlphaSliderHost_OnMouseLeftButtonDown"
                          MouseMove="AlphaSliderHost_OnMouseMove"
                          MouseLeftButtonUp="PointerSurface_OnMouseLeftButtonUp"
                          LostMouseCapture="PointerSurface_OnLostMouseCapture"
                          SizeChanged="InteractiveSurface_OnSizeChanged">
                        <Border CornerRadius="6" Background="{StaticResource CheckerboardBrush}" />
                        <Border x:Name="AlphaGradientBorder" CornerRadius="6" />
                        <Canvas IsHitTestVisible="False">
                            <Ellipse x:Name="AlphaSelector"
                                     Width="18"
                                     Height="18"
                                     Stroke="White"
                                     StrokeThickness="2.5"
                                     Fill="{DynamicResource Theme.SurfaceBackgroundBrush}">
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="6"
                                                      ShadowDepth="1"
                                                      Opacity="0.2"
                                                      Color="#FF000000" />
                                </Ellipse.Effect>
                            </Ellipse>
                        </Canvas>
                    </Grid>

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Width="42"
                                Height="42"
                                CornerRadius="21"
                                Background="{StaticResource CheckerboardBrush}"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource Theme.BorderSoftBrush}">
                            <Ellipse x:Name="PreviewEllipse"
                                     Width="36"
                                     Height="36"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Stroke="#44FFFFFF"
                                     StrokeThickness="1.5" />
                        </Border>

                        <Border x:Name="HexInputBorder"
                                Grid.Column="2"
                                Height="42"
                                Padding="14,0"
                                CornerRadius="15"
                                Background="{DynamicResource Theme.InputBackgroundBrush}"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource Theme.InputBorderBrush}">
                            <TextBox x:Name="HexTextBox"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontFamily="Consolas"
                                     FontSize="15"
                                     FontWeight="SemiBold"
                                     Foreground="{DynamicResource Theme.PrimaryTextBrush}"
                                     VerticalContentAlignment="Center"
                                     TextChanged="HexTextBox_OnTextChanged"
                                     MaxLength="9" />
                        </Border>
                    </Grid>

                    <primitives:UniformGrid x:Name="PresetSwatchPanel"
                                            Margin="0,10,0,0"
                                            Height="84"
                                            Rows="2"
                                            Columns="6" />
                </StackPanel>

                <Grid Grid.Row="2" Margin="12,0,12,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="CancelButton"
                                Width="92"
                                Margin="0,0,10,0"
                                Style="{StaticResource NeutralButtonStyle}"
                                Click="CancelButton_OnClick" />
                        <Button x:Name="OkButton"
                                Width="92"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="OkButton_OnClick" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
