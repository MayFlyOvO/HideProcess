<Window x:Class="BossKey.App.ThemeSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Width="980"
        Height="760"
        MinWidth="920"
        MinHeight="700"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Theme.WindowBackgroundBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        FontFamily="Segoe UI Variable Text">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="0"
                            CornerRadius="16"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <FontFamily x:Key="MaterialIconFontFamily">pack://application:,,,/Assets/Fonts/#Material Icons Round</FontFamily>

        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.IconBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" CornerRadius="8" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Theme.ButtonNeutralHoverBackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NeutralButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.ButtonNeutralBorderBrush}" />
            <Setter Property="Background" Value="{DynamicResource Theme.ButtonNeutralBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.ButtonNeutralForegroundBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="10"
                                BorderThickness="1"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Theme.ButtonNeutralHoverBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource NeutralButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource Theme.ButtonPrimaryBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.ButtonPrimaryBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.ButtonPrimaryForegroundBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="10"
                                BorderThickness="1"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Theme.ButtonPrimaryHoverBackgroundBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Theme.ButtonPrimaryHoverBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ColorTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.PrimaryTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource Theme.InputBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.InputBorderBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Root"
                                CornerRadius="10"
                                BorderThickness="1"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Theme.InputFocusBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Theme.InputHoverBackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PreviewSwitchStyle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="SwitchTrack"
                                    Width="42"
                                    Height="24"
                                    CornerRadius="12"
                                    BorderThickness="1"
                                    Background="{DynamicResource Theme.SwitchTrackBrush}"
                                    BorderBrush="{DynamicResource Theme.SwitchBorderBrush}">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8"
                                                      ShadowDepth="1"
                                                      Opacity="0.12"
                                                      Color="#FF000000" />
                                </Border.Effect>
                            </Border>
                            <Border x:Name="SwitchThumb"
                                    Width="20"
                                    Height="20"
                                    Margin="2,0,0,0"
                                    CornerRadius="10"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource Theme.SwitchThumbBrush}">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10"
                                                      ShadowDepth="2"
                                                      Opacity="0.18"
                                                      Color="#FF000000" />
                                </Border.Effect>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="{DynamicResource Theme.CheckBoxHoverBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="{DynamicResource Theme.SwitchTrackOnBrush}" />
                                <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="{DynamicResource Theme.SwitchTrackOnBrush}" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ThicknessAnimation Storyboard.TargetName="SwitchThumb"
                                                                Storyboard.TargetProperty="Margin"
                                                                To="20,0,0,0"
                                                                Duration="0:0:0.14" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ThicknessAnimation Storyboard.TargetName="SwitchThumb"
                                                                Storyboard.TargetProperty="Margin"
                                                                To="2,0,0,0"
                                                                Duration="0:0:0.14" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PreviewStatusBadgeIconStyle" TargetType="TextBlock">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="LineHeight" Value="14" />
            <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
            <Setter Property="Margin" Value="0,1,0,-1" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="{StaticResource MaterialIconFontFamily}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.StatusBadgeIconBrush}" />
        </Style>

        <Style x:Key="PreviewStatusBadgeIconSpacedStyle" TargetType="TextBlock" BasedOn="{StaticResource PreviewStatusBadgeIconStyle}">
            <Setter Property="Margin" Value="2,0,0,0" />
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource Theme.WindowBackgroundBrush}">
        <Border Margin="0"
                CornerRadius="16"
                Background="{DynamicResource Theme.SurfaceBackgroundBrush}"
                BorderThickness="0"
                BorderBrush="Transparent"
                ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="46" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="{DynamicResource Theme.ChromeBackgroundBrush}" MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                        <Border Width="28"
                                Height="28"
                                CornerRadius="10"
                                Background="{DynamicResource Theme.SubtleBackgroundStrongBrush}"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource Theme.BorderSoftBrush}"><!--
                            <TextBlock Text="◐"
                                       FontFamily="Segoe UI Symbol"
                                       FontSize="14"
                                       Foreground="{DynamicResource Theme.ButtonPrimaryBackgroundBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />-->
                            <Grid>
                                <Border Width="10"
                                        Height="10"
                                        Margin="0,0,6,6"
                                        CornerRadius="5"
                                        Background="{DynamicResource Theme.ButtonPrimaryBackgroundBrush}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                                <Border Width="10"
                                        Height="10"
                                        Margin="6,0,0,6"
                                        CornerRadius="5"
                                        Background="{DynamicResource Theme.ButtonSuccessBackgroundBrush}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                                <Border Width="10"
                                        Height="10"
                                        Margin="0,7,0,0"
                                        CornerRadius="5"
                                        Background="{DynamicResource Theme.WarningBrush}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <TextBlock x:Name="HeaderTextBlock"
                                   Margin="8,0,0,0"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Theme.PrimaryTextBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <Button Grid.Column="1" Margin="0,0,8,0" Style="{StaticResource TitleBarButtonStyle}" Click="CloseButton_OnClick">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe Fluent Icons" FontSize="10" />
                    </Button>
                </Grid>

                    <Grid Grid.Row="1" Margin="18,16,18,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="0.8*" />
                        </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Padding="18"
                            CornerRadius="14"
                            Background="{DynamicResource Theme.PanelBackgroundBrush}"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource Theme.BorderStrongBrush}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock x:Name="ThemeModeLabelTextBlock" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Theme.SectionHeadingBrush}" />

                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
                                <Button x:Name="LightModeButton" Width="112" Height="38" Margin="0,0,8,0" Style="{StaticResource NeutralButtonStyle}" Click="LightModeButton_OnClick" />
                                <Button x:Name="DarkModeButton" Width="112" Height="38" Style="{StaticResource NeutralButtonStyle}" Click="DarkModeButton_OnClick" />
                            </StackPanel>

                            <Grid Grid.Row="2" Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock x:Name="ThemeHintTextBlock" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Theme.PrimaryTextBrush}" />
                                    <TextBlock x:Name="ThemeSubHintTextBlock" Margin="0,4,0,0" FontSize="12" Foreground="{DynamicResource Theme.SecondaryTextBrush}" TextWrapping="Wrap" />
                                </StackPanel>

                                <Button x:Name="ResetCurrentModeButton" Grid.Column="1" MinWidth="108" Height="36" Margin="12,0,8,0" Style="{StaticResource NeutralButtonStyle}" Click="ResetCurrentModeButton_OnClick" />
                                <Button x:Name="ResetAllButton" Grid.Column="2" MinWidth="88" Height="36" Style="{StaticResource NeutralButtonStyle}" Click="ResetAllButton_OnClick" />
                            </Grid>

                            <Border Grid.Row="3"
                                    Margin="0,16,0,0"
                                    Padding="12"
                                    CornerRadius="12"
                                    Background="{DynamicResource Theme.SurfaceBackgroundBrush}"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource Theme.BorderBrush}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="58" />
                                            <ColumnDefinition Width="148" />
                                            <ColumnDefinition Width="58" />
                                            <ColumnDefinition Width="58" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="ColorColumnLabelTextBlock" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource Theme.SecondaryTextBrush}" />
                                        <TextBlock x:Name="SwatchColumnLabelTextBlock" Grid.Column="1" HorizontalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource Theme.SecondaryTextBrush}" />
                                        <TextBlock x:Name="HexColumnLabelTextBlock" Grid.Column="2" HorizontalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource Theme.SecondaryTextBrush}" />
                                    </Grid>

                                    <ScrollViewer Grid.Row="1" Margin="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                        <ItemsControl x:Name="ColorItemsControl">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="58" />
                                                            <ColumnDefinition Width="148" />
                                                            <ColumnDefinition Width="58" />
                                                            <ColumnDefinition Width="58" />
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Theme.PrimaryTextBrush}" />
                                                            <TextBlock Text="{Binding Description}" Margin="0,2,0,0" FontSize="11" Foreground="{DynamicResource Theme.SecondaryTextBrush}" TextWrapping="Wrap" />
                                                        </StackPanel>

                                                        <Border Grid.Column="1"
                                                                Width="42"
                                                                Height="36"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                CornerRadius="10"
                                                                Background="{Binding PreviewBrush}"
                                                                BorderThickness="1"
                                                                BorderBrush="{DynamicResource Theme.BorderBrush}" />

                                                        <TextBox Grid.Column="2"
                                                                 Margin="10,0,0,0"
                                                                 VerticalAlignment="Center"
                                                                 Style="{StaticResource ColorTextBoxStyle}"
                                                                 Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />

                                                        <Button Grid.Column="3" Height="36" Margin="10,0,0,0" VerticalAlignment="Center" Style="{StaticResource NeutralButtonStyle}" Tag="{Binding}" Click="PickColorButton_OnClick" Content="{Binding PickText}" />
                                                        <Button Grid.Column="4" Height="36" Margin="8,0,0,0" VerticalAlignment="Center" Style="{StaticResource NeutralButtonStyle}" Tag="{Binding}" Click="ResetColorButton_OnClick" Content="{Binding ResetText}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <TextBlock x:Name="ValidationTextBlock"
                                               Grid.Row="2"
                                               Margin="0,8,0,0"
                                               FontSize="12"
                                               Foreground="{DynamicResource Theme.WarningBrush}"
                                               Visibility="Collapsed" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            Padding="18"
                            CornerRadius="14"
                            Background="{DynamicResource Theme.PanelBackgroundBrush}"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource Theme.BorderStrongBrush}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock x:Name="PreviewLabelTextBlock" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Theme.SectionHeadingBrush}" />
                            <TextBlock x:Name="PreviewHintTextBlock" Grid.Row="1" Margin="0,6,0,0" FontSize="12" Foreground="{DynamicResource Theme.SecondaryTextBrush}" TextWrapping="Wrap" />

                            <Border Grid.Row="2"
                                    Margin="0,16,0,0"
                                    CornerRadius="16"
                                    Background="Transparent"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource Theme.BorderStrongBrush}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="42" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Border Margin="1,1,1,0"
                                            CornerRadius="15,15,0,0"
                                            Background="{DynamicResource Theme.ChromeBackgroundBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock x:Name="PreviewWindowTitleTextBlock"
                                                       Margin="14,0,0,0"
                                                       FontSize="12.5"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Theme.PrimaryTextBrush}"
                                                       VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,8,0"
                                                        IsHitTestVisible="False">
                                                <Button Style="{StaticResource TitleBarButtonStyle}">
                                                    <TextBlock Text="&#xE921;"
                                                               FontFamily="Segoe Fluent Icons"
                                                               FontSize="10" />
                                                </Button>
                                                <Button Style="{StaticResource TitleBarButtonStyle}">
                                                    <TextBlock Text="&#xE922;"
                                                               FontFamily="Segoe Fluent Icons"
                                                               FontSize="10" />
                                                </Button>
                                                <Button Style="{StaticResource TitleBarButtonStyle}"
                                                        Margin="0">
                                                    <TextBlock Text="&#xE8BB;"
                                                               FontFamily="Segoe Fluent Icons"
                                                               FontSize="10" />
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="1"
                                            Margin="1,0,1,1"
                                            CornerRadius="0,0,15,15"
                                            Background="{DynamicResource Theme.WindowBackgroundBrush}">
                                        <StackPanel Margin="16">
                                            <Border Padding="14"
                                                    CornerRadius="14"
                                                    Background="{DynamicResource Theme.SurfaceBackgroundBrush}"
                                                    BorderThickness="1"
                                                    BorderBrush="{DynamicResource Theme.BorderBrush}">
                                                <StackPanel>
                                                    <TextBlock x:Name="PreviewCardTitleTextBlock" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource Theme.PrimaryTextBrush}" />
                                                    <TextBlock x:Name="PreviewCardSubtitleTextBlock" Margin="0,6,0,0" FontSize="12.5" Foreground="{DynamicResource Theme.SecondaryTextBrush}" TextWrapping="Wrap" />
                                                    <Grid Margin="0,14,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Button x:Name="PreviewNeutralButton" Grid.Column="0" Height="38" Margin="0,0,8,0" Style="{StaticResource NeutralButtonStyle}" />
                                                        <Button x:Name="PreviewPrimaryButton" Grid.Column="1" Height="38" Margin="0,0,8,0" Style="{StaticResource PrimaryButtonStyle}" />
                                                        <Border Grid.Column="2"
                                                                Height="38"
                                                                Padding="10,0"
                                                                CornerRadius="10"
                                                                Background="{DynamicResource Theme.WarningSoftBrush}"
                                                                BorderThickness="1"
                                                                BorderBrush="{DynamicResource Theme.BorderSoftBrush}">
                                                            <TextBlock x:Name="PreviewWarningBadgeTextBlock"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource Theme.WarningBrush}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </Border>
                                                    </Grid>
                                                    <Grid Margin="0,16,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <Border Padding="12,10" CornerRadius="12" Background="{DynamicResource Theme.InputBackgroundBrush}" BorderThickness="1" BorderBrush="{DynamicResource Theme.InputBorderBrush}">
                                                            <TextBlock x:Name="PreviewInputTextBlock" FontSize="12.5" Foreground="{DynamicResource Theme.PrimaryTextBrush}" />
                                                        </Border>
                                                        <CheckBox Grid.Column="1"
                                                                  x:Name="PreviewSwitchCheckBox"
                                                                  Width="42"
                                                                  Height="24"
                                                                  Margin="12,0,0,0"
                                                                  VerticalAlignment="Center"
                                                                  IsChecked="True"
                                                                  Style="{StaticResource PreviewSwitchStyle}" />
                                                    </Grid>
                                                </StackPanel>
                                            </Border>

                                            <Border Margin="0,14,0,0"
                                                    Width="118"
                                                    Padding="12"
                                                    HorizontalAlignment="Left"
                                                    CornerRadius="16"
                                                    Background="{DynamicResource Theme.SurfaceBackgroundBrush}"
                                                    BorderThickness="1"
                                                    BorderBrush="{DynamicResource Theme.BorderSoftBrush}">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid Width="56"
                                                          Height="56"
                                                          Margin="0,4,0,0"
                                                          HorizontalAlignment="Center">
                                                        <Border Width="56"
                                                                Height="56"
                                                                CornerRadius="18"
                                                                Background="{DynamicResource Theme.SubtleBackgroundBrush}"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center">
                                                            <Image Width="36"
                                                                   Height="36"
                                                                   Source="pack://application:,,,/Assets/BossKey.ico"
                                                                   Stretch="Uniform"
                                                                   VerticalAlignment="Center"
                                                                   HorizontalAlignment="Center" />
                                                        </Border>
                                                        <Border x:Name="PreviewTileStatusBadgeBorder"
                                                                MinWidth="24"
                                                                Height="24"
                                                                Padding="6,0"
                                                                Margin="0,-12,-21,0"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Top"
                                                                Panel.ZIndex="2"
                                                                CornerRadius="12"
                                                                Background="{DynamicResource Theme.StatusBadgeBackgroundBrush}"
                                                                BorderThickness="1"
                                                                BorderBrush="{DynamicResource Theme.StatusBadgeBorderBrush}">
                                                            <StackPanel Orientation="Horizontal"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center">
                                                                <TextBlock Text="&#xEB3B;"
                                                                           Style="{StaticResource PreviewStatusBadgeIconStyle}" />
                                                                <TextBlock Text="&#xF10D;"
                                                                           Style="{StaticResource PreviewStatusBadgeIconSpacedStyle}" />
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>

                                                    <TextBlock Grid.Row="1"
                                                               Margin="0,10,0,0"
                                                               FontSize="12.5"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource Theme.PrimaryTextBrush}"
                                                               Text="BossKey"
                                                               TextAlignment="Center"
                                                               TextWrapping="Wrap"
                                                               MaxHeight="34"
                                                               TextTrimming="CharacterEllipsis" />
                                                </Grid>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Row="2" Margin="18,16,18,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="FooterHintTextBlock" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource Theme.SecondaryTextBrush}" TextWrapping="Wrap" />

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="CancelButton" Width="130" Height="40" Margin="0,0,10,0" Style="{StaticResource NeutralButtonStyle}" Click="CancelButton_OnClick" />
                        <Button x:Name="SaveButton" Width="130" Height="40" Style="{StaticResource PrimaryButtonStyle}" Click="SaveButton_OnClick" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
