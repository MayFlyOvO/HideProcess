                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="2"
                                Margin="0,12,0,0"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button x:Name="HideNowButton"
                                Width="130"
                                Height="40"
                                Margin="0,0,10,0"
                                Style="{StaticResource IconSolidButtonStyle}"
                                Background="{DynamicResource Theme.ButtonSuccessBackgroundBrush}"
                                BorderBrush="{DynamicResource Theme.ButtonSuccessBorderBrush}"
                                Foreground="{DynamicResource Theme.ButtonSuccessForegroundBrush}"
                                Click="HideNowButton_OnClick">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8F5;"
                                           FontFamily="{StaticResource MaterialIconFontFamily}"
                                           FontSize="13"
                                           VerticalAlignment="Center" />
                                <TextBlock x:Name="HideNowButtonTextBlock"
                                           Margin="7,0,0,0"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="ShowNowButton"
                                Width="130"
                                Height="40"
                                Margin="0,0,10,0"
                                Style="{StaticResource IconSolidButtonStyle}"
                                Background="{DynamicResource Theme.ButtonPrimaryBackgroundBrush}"
                                BorderBrush="{DynamicResource Theme.ButtonPrimaryBorderBrush}"
                                Foreground="{DynamicResource Theme.ButtonPrimaryForegroundBrush}"
                                Click="ShowNowButton_OnClick">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8F4;"
                                           FontFamily="{StaticResource MaterialIconFontFamily}"
                                           FontSize="13"
                                           VerticalAlignment="Center" />
                                <TextBlock x:Name="ShowNowButtonTextBlock"
                                           Margin="7,0,0,0"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="OpenSettingsButton"
                                Width="130"
                                Height="40"
                                Style="{StaticResource IconNeutralButtonStyle}"
                                Click="OpenSettingsButton_OnClick">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8B8;"
                                           FontFamily="{StaticResource MaterialIconFontFamily}"
                                           FontSize="13"
                                           VerticalAlignment="Center" />
                                <TextBlock x:Name="OpenSettingsButtonTextBlock"
                                           Margin="7,0,0,0"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <Border Grid.Row="3"
                            Margin="0,12,0,0"
                            Padding="12"
                            CornerRadius="12"
                            Background="{DynamicResource Theme.SurfaceBackgroundBrush}"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource Theme.BorderStrongBrush}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="LogTitleTextBlock"
                                       Grid.Column="0"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource Theme.SectionHeadingBrush}"
                                       VerticalAlignment="Center" />

                            <TextBlock x:Name="StatusTextBlock"
                                       Grid.Column="1"
                                       Margin="12,0,12,0"
                                       FontSize="12"
                                       Foreground="{DynamicResource Theme.SecondaryTextBrush}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Visibility="Collapsed" />

                            <Button Grid.Column="2"
                                    x:Name="ToggleLogsButton"
                                    Width="108"
                                    Height="32"
                                    Margin="0,0,8,0"
                                    Style="{StaticResource IconNeutralButtonStyle}"
                                    Click="ToggleLogsButton_OnClick">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock x:Name="ToggleLogsGlyphTextBlock"
                                               Text="&#xE5CE;"
                                               FontFamily="{StaticResource MaterialIconFontFamily}"
                                               FontSize="11"
                                               VerticalAlignment="Center" />
                                    <TextBlock x:Name="ToggleLogsButtonTextBlock"
                                               Margin="6,0,0,0"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="3"
                                    x:Name="ClearLogsButton"
                                    Width="108"
                                    Height="32"
                                    Style="{StaticResource IconNeutralButtonStyle}"
                                    Click="ClearLogsButton_OnClick">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE92B;"
                                               FontFamily="{StaticResource MaterialIconFontFamily}"
                                               FontSize="11"
                                               VerticalAlignment="Center" />
                                    <TextBlock x:Name="ClearLogsButtonTextBlock"
                                               Margin="6,0,0,0"
                                               VerticalAlignment="Center" />
                                    </StackPanel>
                            </Button>

                            <ListBox x:Name="LogListBox"
                                     Grid.Row="1"
                                     Grid.ColumnSpan="4"
                                     Margin="0,10,0,0"
                                     Height="110"
                                     BorderThickness="1"
                                     BorderBrush="{DynamicResource Theme.BorderBrush}"
                                     Background="{DynamicResource Theme.SurfaceBackgroundBrush}"
                                     Foreground="{DynamicResource Theme.PrimaryTextBrush}"
                                     ItemsSource="{Binding LogEntries}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Foreground="{DynamicResource Theme.PrimaryTextBrush}"
                                                   Text="{Binding}" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Grid Visibility="{Binding UpdateDownloadOverlayVisibility}"
              Background="{DynamicResource Theme.OverlayBackdropBrush}"
              Panel.ZIndex="20">
            <Border Width="248"
                    Height="248"
                    Padding="24"
                    Background="{DynamicResource Theme.OverlayCardBackgroundBrush}"
                    BorderBrush="{DynamicResource Theme.OverlayCardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="28"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Grid Width="120"
                          Height="120"
                          HorizontalAlignment="Center">
                        <Path Data="M 60,8 A 52,52 0 1 1 60,112 A 52,52 0 1 1 60,8"
                              Stretch="None"
                              Stroke="{DynamicResource Theme.OverlayTrackBrush}"
                              StrokeThickness="8" />
                        <Path Data="{Binding UpdateDownloadArcData}"
                              Stretch="None"
                              Stroke="{DynamicResource Theme.OverlayAccentBrush}"
                              StrokeThickness="8"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round" />
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding UpdateDownloadProgressText}"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource Theme.PrimaryTextBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="%"
                                       Visibility="Collapsed" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Margin="0,18,0,0"
                               Text="{Binding UpdateDownloadTitleText}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Theme.PrimaryTextBrush}"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
