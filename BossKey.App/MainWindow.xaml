<Window x:Class="BossKey.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Width="980"
        Height="700"
        MinWidth="900"
        MinHeight="620"
        WindowStyle="None"
        Icon="pack://application:,,,/Assets/BossKey.ico"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Theme.WindowBackgroundBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        FontFamily="Segoe UI Variable Text">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            CornerRadius="16"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <FontFamily x:Key="MaterialIconFontFamily">pack://application:,,,/Assets/Fonts/#Material Icons Round</FontFamily>

        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.IconBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="8"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Theme.ButtonNeutralHoverBackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconNeutralButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.ButtonNeutralBorderBrush}" />
            <Setter Property="Background" Value="{DynamicResource Theme.ButtonNeutralBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.ButtonNeutralForegroundBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="10"
                                BorderThickness="1"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Theme.ButtonNeutralHoverBackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource IconNeutralButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource Theme.ButtonPrimaryBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.ButtonPrimaryBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.ButtonPrimaryForegroundBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="10"
                                BorderThickness="1"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Theme.ButtonPrimaryHoverBackgroundBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Theme.ButtonPrimaryHoverBackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconSolidButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.ButtonPrimaryBorderBrush}" />
            <Setter Property="Background" Value="{DynamicResource Theme.ButtonPrimaryBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.ButtonPrimaryForegroundBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="10"
                                BorderThickness="1"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FlatCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource Theme.SecondaryTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border x:Name="Box"
                                    Width="18"
                                    Height="18"
                                    CornerRadius="5"
                                    BorderThickness="1.5"
                                    BorderBrush="{DynamicResource Theme.CheckBoxBorderBrush}"
                                    Background="{DynamicResource Theme.InputBackgroundBrush}"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center" />

                            <Path x:Name="CheckMark"
                                  Width="10"
                                  Height="8"
                                  Data="M 0.8 4.2 L 3.8 7.2 L 9.2 1.0"
                                  Stretch="Fill"
                                  Stroke="White"
                                  StrokeThickness="2.2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Visibility="Collapsed"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center" />

                            <ContentPresenter Grid.Column="1"
                                              Margin="8,0,0,0"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              RecognizesAccessKey="True" />
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="{DynamicResource Theme.ButtonPrimaryBackgroundBrush}" />
                                <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Theme.ButtonPrimaryBackgroundBrush}" />
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Theme.CheckBoxHoverBorderBrush}" />
                                <Setter TargetName="Box" Property="Background" Value="{DynamicResource Theme.CheckBoxHoverBackgroundBrush}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Box" Property="Background" Value="{DynamicResource Theme.ButtonPrimaryHoverBackgroundBrush}" />
                                <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Theme.ButtonPrimaryHoverBackgroundBrush}" />
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.PrimaryTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                CornerRadius="7"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource Theme.ComboItemHoverBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource Theme.ComboItemSelectedBackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource Theme.InputBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.InputBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.PrimaryTextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="12,0,34,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    CornerRadius="10"
                                    BorderThickness="1"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}">
                                <Grid>
                                    <ContentPresenter Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" />
                                    <TextBlock Text="&#xE313;"
                                               FontFamily="{StaticResource MaterialIconFontFamily}"
                                               FontSize="14"
                                               Foreground="{DynamicResource Theme.IconBrush}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"
                                               Margin="0,0,12,0" />
                                </Grid>
                            </Border>

                            <ToggleButton x:Name="DropDownToggle"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          ClickMode="Press"
                                          Background="Transparent"
                                          BorderBrush="Transparent">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" />
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   PopupAnimation="Slide">
                                <Border Margin="0,4,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        CornerRadius="10"
                                        Background="{DynamicResource Theme.SurfaceBackgroundBrush}"
                                        BorderThickness="1"
                                        BorderBrush="{DynamicResource Theme.BorderBrush}">
                                    <ScrollViewer MaxHeight="220">
                                        <StackPanel IsItemsHost="True" Margin="4" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="Background" Value="{DynamicResource Theme.InputHoverBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource Theme.InputFocusBorderBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GroupActionButtonStyle" TargetType="Button" BasedOn="{StaticResource IconNeutralButtonStyle}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="GroupHotkeyButtonStyle" TargetType="Button" BasedOn="{StaticResource IconNeutralButtonStyle}">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="10,6" />
        </Style>

        <Style x:Key="TileRemoveButtonStyle" TargetType="Button" BasedOn="{StaticResource IconNeutralButtonStyle}">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="IconOnlyCheckBoxStyle" TargetType="CheckBox" BasedOn="{StaticResource FlatCheckBoxStyle}">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="TargetContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="HasDropShadow" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border CornerRadius="12"
                                Background="{DynamicResource Theme.SurfaceBackgroundBrush}"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource Theme.BorderBrush}"
                                Padding="6">
                            <StackPanel IsItemsHost="True"
                                        KeyboardNavigation.DirectionalNavigation="Cycle" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TargetContextMenuSeparatorStyle" TargetType="Separator">
            <Setter Property="Margin" Value="12,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1"
                                HorizontalAlignment="Stretch"
                                Background="{DynamicResource Theme.BorderBrush}"
                                SnapsToDevicePixels="True" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatusBadgeIconStyle" TargetType="TextBlock">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="LineHeight" Value="14" />
            <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
            <Setter Property="Margin" Value="0,1,0,-1" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="{StaticResource MaterialIconFontFamily}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.StatusBadgeIconBrush}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            <Setter Property="TextOptions.TextRenderingMode" Value="Auto" />
        </Style>

        <Style x:Key="StatusBadgeIconSpacedStyle" TargetType="TextBlock" BasedOn="{StaticResource StatusBadgeIconStyle}">
            <Setter Property="Margin" Value="2,0,0,0" />
        </Style>

        <Style x:Key="StatusBadgeMuteIconStyle" TargetType="TextBlock" BasedOn="{StaticResource StatusBadgeIconStyle}">
            <Setter Property="Margin" Value="0,0,0,0" />
        </Style>

        <Style x:Key="SwitchMenuItemStyle" TargetType="MenuItem">
            <Setter Property="StaysOpenOnClick" Value="True" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.PrimaryTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Root"
                                Background="Transparent"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <Grid MinWidth="188">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ContentPresenter VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"
                                                  ContentSource="Header" />

                                <Grid Grid.Column="1"
                                      Width="42"
                                      Height="24"
                                      Margin="14,0,0,0"
                                      VerticalAlignment="Center">
                                    <Border x:Name="SwitchTrack"
                                            CornerRadius="12"
                                            BorderThickness="1"
                                            Background="{DynamicResource Theme.SwitchTrackBrush}"
                                            BorderBrush="{DynamicResource Theme.SwitchBorderBrush}">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="8"
                                                              ShadowDepth="1"
                                                              Opacity="0.12"
                                                              Color="#FF000000" />
                                        </Border.Effect>
                                    </Border>
                                    <Border x:Name="SwitchThumb"
                                            Width="20"
                                            Height="20"
                                            Margin="2,0,0,0"
                                            CornerRadius="10"
                                            Background="{DynamicResource Theme.SwitchThumbBrush}"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="10"
                                                              ShadowDepth="2"
                                                              Opacity="0.18"
                                                              Color="#FF000000" />
                                        </Border.Effect>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Theme.ButtonNeutralHoverBackgroundBrush}" />
                                <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="{DynamicResource Theme.CheckBoxHoverBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="{DynamicResource Theme.SwitchTrackOnBrush}" />
                                <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="{DynamicResource Theme.SwitchTrackOnBrush}" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ThicknessAnimation Storyboard.TargetName="SwitchThumb"
                                                                Storyboard.TargetProperty="Margin"
                                                                To="20,0,0,0"
                                                                Duration="0:0:0.14">
                                                <ThicknessAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </ThicknessAnimation.EasingFunction>
                                            </ThicknessAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ThicknessAnimation Storyboard.TargetName="SwitchThumb"
                                                                Storyboard.TargetProperty="Margin"
                                                                To="2,0,0,0"
                                                                Duration="0:0:0.14">
                                                <ThicknessAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </ThicknessAnimation.EasingFunction>
                                            </ThicknessAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True" />
                                    <Condition Property="IsHighlighted" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Theme.CheckBoxHoverBackgroundBrush}" />
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ContextActionMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource Theme.PrimaryTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Root"
                                Background="Transparent"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              RecognizesAccessKey="True"
                                              ContentSource="Header" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Theme.ButtonNeutralHoverBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource Theme.WindowBackgroundBrush}">
        <Border Margin="0"
                CornerRadius="16"
                Background="{DynamicResource Theme.WindowBackgroundBrush}"
                BorderThickness="0"
                BorderBrush="Transparent"
                ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="46" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      Background="{DynamicResource Theme.ChromeBackgroundBrush}"
                      MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="14,0,0,0">
                        <Image Width="28"
                               Height="28"
                               Source="pack://application:,,,/Assets/BossKey.ico"
                               VerticalAlignment="Center"
                               SnapsToDevicePixels="True" />
                        <TextBlock x:Name="AppTitleTextBlock"
                                   Margin="8,0,0,0"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Theme.PrimaryTextBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,0,8,0">
                        <Button x:Name="ToggleThemeButton"
                                Style="{StaticResource TitleBarButtonStyle}"
                                Click="ToggleThemeButton_OnClick">
                            <TextBlock x:Name="ThemeToggleGlyphTextBlock"
                                       FontSize="14"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Button>
                        <Border Width="1"
                                Height="16"
                                Margin="2,0,8,0"
                                VerticalAlignment="Center"
                                Background="{DynamicResource Theme.BorderSoftBrush}" />
                        <Button Style="{StaticResource TitleBarButtonStyle}"
                                Click="MinimizeButton_OnClick">
                            <TextBlock Text="&#xE921;"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="10" />
                        </Button>
                        <Button Style="{StaticResource TitleBarButtonStyle}"
                                Click="MaximizeRestoreButton_OnClick">
                            <TextBlock x:Name="MaximizeRestoreGlyphTextBlock"
                                       Text="&#xE922;"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="10" />
                        </Button>
                        <Button Style="{StaticResource TitleBarButtonStyle}"
                                Margin="0"
                                Click="CloseButton_OnClick">
                            <TextBlock Text="&#xE8BB;"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="10" />
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" Margin="16,14,16,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="14"
                            CornerRadius="12"
                            Background="{DynamicResource Theme.SurfaceBackgroundBrush}"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource Theme.BorderStrongBrush}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="RunningLabelTextBlock"
                                       Grid.ColumnSpan="4"
                                       Margin="0,0,0,10"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource Theme.SectionHeadingBrush}" />

                            <ComboBox x:Name="RunningTargetsComboBox"
                                       Grid.Row="1"
                                       Margin="0,0,12,0"
                                       Height="40"
                                       Style="{StaticResource RoundedComboBoxStyle}"
                                       ItemContainerStyle="{StaticResource RoundedComboBoxItemStyle}"
                                       FontSize="14"
                                       VerticalContentAlignment="Center"
                                      DisplayMemberPath="DisplayText" />

                            <Button x:Name="RefreshTargetsButton"
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Margin="0,0,8,0"
                                    Width="96"
                                    Height="40"
                                    Style="{StaticResource IconNeutralButtonStyle}"
                                    Click="RefreshTargetsButton_OnClick">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE5D5;"
                                               FontFamily="{StaticResource MaterialIconFontFamily}"
                                               FontSize="13"
                                               VerticalAlignment="Center" />
                                    <TextBlock x:Name="RefreshButtonTextBlock"
                                               Margin="7,0,0,0"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button x:Name="AddTargetButton"
                                    Grid.Row="1"
                                    Grid.Column="2"
                                    Margin="0,0,8,0"
                                    Width="96"
                                    Height="40"
                                    Style="{StaticResource IconPrimaryButtonStyle}"
                                    Click="AddTargetButton_OnClick">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE145;"
                                               FontFamily="{StaticResource MaterialIconFontFamily}"
                                               FontSize="13"
                                               VerticalAlignment="Center" />
                                    <TextBlock x:Name="AddTargetButtonTextBlock"
                                               Margin="7,0,0,0"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
