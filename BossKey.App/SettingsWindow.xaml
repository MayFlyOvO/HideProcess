<Window x:Class="BossKey.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Width="720"
        Height="810"
        MinWidth="680"
        MinHeight="770"
        WindowStyle="None"
        Icon="pack://application:,,,/Assets/BossKey.ico"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#FFF6F8FB"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        FontFamily="Segoe UI Variable Text">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="0"
                            CornerRadius="16"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <FontFamily x:Key="MaterialIconFontFamily">pack://application:,,,/Assets/Fonts/#Material Icons Round</FontFamily>

        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#00FFFFFF" />
            <Setter Property="BorderBrush" Value="#00FFFFFF" />
            <Setter Property="Foreground" Value="#4B5563" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="8"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFEFF2F6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NeutralButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="BorderBrush" Value="#FFE4E7EB" />
            <Setter Property="Background" Value="#FFFFFFFF" />
            <Setter Property="Foreground" Value="#25313D" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="10"
                                BorderThickness="1"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFF7F8FA" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource NeutralButtonStyle}">
            <Setter Property="Background" Value="#FF0A84FF" />
            <Setter Property="BorderBrush" Value="#FF0A84FF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="10"
                                BorderThickness="1"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FF0077EE" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#FF0077EE" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FlatLabeledCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#25313D" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border x:Name="SwitchTrack"
                                    Grid.Column="1"
                                    Width="42"
                                    Height="24"
                                    CornerRadius="12"
                                    BorderThickness="1"
                                    VerticalAlignment="Center"
                                    Background="#FFFFFFFF"
                                    BorderBrush="#FFDDE3EA">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8"
                                                      ShadowDepth="1"
                                                      Opacity="0.12"
                                                      Color="#FF000000" />
                                </Border.Effect>
                            </Border>

                            <Border x:Name="SwitchThumb"
                                    Grid.Column="1"
                                    Width="20"
                                    Height="20"
                                    CornerRadius="10"
                                    Background="#FFFFFFFF"
                                    Margin="2,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10"
                                                      ShadowDepth="2"
                                                      Opacity="0.18"
                                                      Color="#FF000000" />
                                </Border.Effect>
                            </Border>

                            <ContentPresenter Grid.Column="0"
                                              Margin="0,0,10,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Stretch"
                                              RecognizesAccessKey="True" />
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ThicknessAnimation Storyboard.TargetName="SwitchThumb"
                                                                Storyboard.TargetProperty="Margin"
                                                                To="20,0,0,0"
                                                                Duration="0:0:0.16">
                                                <ThicknessAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </ThicknessAnimation.EasingFunction>
                                            </ThicknessAnimation>
                                            <ColorAnimation Storyboard.TargetName="SwitchTrack"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="#FF4CD964"
                                                            Duration="0:0:0.16" />
                                            <ColorAnimation Storyboard.TargetName="SwitchTrack"
                                                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                            To="#FF4CD964"
                                                            Duration="0:0:0.16" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ThicknessAnimation Storyboard.TargetName="SwitchThumb"
                                                                Storyboard.TargetProperty="Margin"
                                                                To="2,0,0,0"
                                                                Duration="0:0:0.16">
                                                <ThicknessAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </ThicknessAnimation.EasingFunction>
                                            </ThicknessAnimation>
                                            <ColorAnimation Storyboard.TargetName="SwitchTrack"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="#FFFFFFFF"
                                                            Duration="0:0:0.16" />
                                            <ColorAnimation Storyboard.TargetName="SwitchTrack"
                                                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                            To="#FFDDE3EA"
                                                            Duration="0:0:0.16" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Foreground" Value="#25313D" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                CornerRadius="7"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#FFEFF4FB" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#FFE7F0FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#FFFFFFFF" />
            <Setter Property="BorderBrush" Value="#FFE4E7EB" />
            <Setter Property="Foreground" Value="#25313D" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="12,0,34,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    CornerRadius="10"
                                    BorderThickness="1"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}">
                                <Grid>
                                    <ContentPresenter Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" />
                                    <TextBlock Text="&#xE313;"
                                               FontFamily="{StaticResource MaterialIconFontFamily}"
                                               FontSize="14"
                                               Foreground="#667385"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"
                                               Margin="0,0,12,0" />
                                </Grid>
                            </Border>

                            <ToggleButton x:Name="DropDownToggle"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          ClickMode="Press"
                                          Background="Transparent"
                                          BorderBrush="Transparent">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" />
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   PopupAnimation="Slide">
                                <Border Margin="0,4,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        CornerRadius="10"
                                        Background="White"
                                        BorderThickness="1"
                                        BorderBrush="#FFE4E7EB">
                                    <ScrollViewer MaxHeight="220">
                                        <StackPanel IsItemsHost="True" Margin="4" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="Background" Value="#FFF9FAFC" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#FF7AA8FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="GroupHotkeyOptionTemplate">
            <StackPanel Orientation="Horizontal">
                <Border Width="22"
                        Height="22"
                        CornerRadius="7"
                        Background="{Binding IconColor}"
                        BorderThickness="1"
                        BorderBrush="{Binding IconColor}"
                        VerticalAlignment="Center">
                    <TextBlock Text="&#xE2C7;"
                               FontFamily="{StaticResource MaterialIconFontFamily}"
                               FontSize="11"
                               Foreground="#4B6B8A"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center" />
                </Border>
                <TextBlock Margin="8,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="#25313D"
                           Text="{Binding DisplayName}" />
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="#FFF6F8FB">
        <Border Margin="0"
                CornerRadius="16"
                Background="White"
                BorderThickness="0"
                BorderBrush="#00FFFFFF"
                ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="46" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      Background="#FFF7F8FA"
                      MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="14,0,0,0">
                        <Image Width="28"
                               Height="28"
                               Source="pack://application:,,,/Assets/BossKey.ico"
                               VerticalAlignment="Center"
                               SnapsToDevicePixels="True" />
                        <TextBlock x:Name="HeaderTextBlock"
                                   Margin="8,0,0,0"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#1F2937"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Margin="0,0,8,0">
                        <Button x:Name="AboutButton"
                                Style="{StaticResource TitleBarButtonStyle}"
                                Margin="0,0,6,0"
                                Click="AboutButton_OnClick">
                            <TextBlock Text="&#xE88E;"
                                       FontFamily="{StaticResource MaterialIconFontFamily}"
                                       FontSize="10" />
                        </Button>
                        <Button Style="{StaticResource TitleBarButtonStyle}"
                                Click="CloseButton_OnClick">
                            <TextBlock Text="&#xE8BB;"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="10" />
                        </Button>
                    </StackPanel>
                </Grid>

                <ScrollViewer Grid.Row="1"
                              Margin="16,14,16,0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="False">
                    <StackPanel Margin="0,0,2,0">
                    <Border Margin="0,0,0,14"
                            Padding="16"
                            CornerRadius="12"
                            Background="#FFFAFBFD"
                            BorderThickness="1"
                            BorderBrush="#FFE9EDF3">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="130" />
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="HotkeysSectionTextBlock"
                                       Grid.ColumnSpan="3"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#334155" />

                            <TextBlock x:Name="HideHotkeyLabel"
                                       Grid.Row="1"
                                       Margin="0,14,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       Foreground="#4A5560" />
                            <Border Grid.Row="1"
                                    Grid.Column="1"
                                    Margin="0,14,12,0"
                                    Padding="10,8"
                                    CornerRadius="8"
                                    Background="#FFFFFFFF"
                                    BorderThickness="1"
                                    BorderBrush="#FFE4E7EB">
                                <TextBlock x:Name="HideHotkeyValueTextBlock"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#1F2933" />
                            </Border>
                            <Button x:Name="SetHideHotkeyButton"
                                    Grid.Row="1"
                                    Grid.Column="2"
                                    Margin="0,14,0,0"
                                    Style="{StaticResource NeutralButtonStyle}"
                                    Click="SetHideHotkeyButton_OnClick">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE3C9;"
                                               FontFamily="{StaticResource MaterialIconFontFamily}"
                                               FontSize="12"
                                               VerticalAlignment="Center" />
                                    <TextBlock x:Name="SetHideHotkeyButtonTextBlock"
                                               Margin="6,0,0,0"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <TextBlock x:Name="ShowHotkeyLabel"
                                       Grid.Row="2"
                                       Margin="0,12,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       Foreground="#4A5560" />
                            <Border Grid.Row="2"
                                    Grid.Column="1"
                                    Margin="0,12,12,0"
                                    Padding="10,8"
                                    CornerRadius="8"
                                    Background="#FFFFFFFF"
                                    BorderThickness="1"
                                    BorderBrush="#FFE4E7EB">
                                <TextBlock x:Name="ShowHotkeyValueTextBlock"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#1F2933" />
                            </Border>
                            <Button x:Name="SetShowHotkeyButton"
                                    Grid.Row="2"
                                    Grid.Column="2"
                                    Margin="0,12,0,0"
                                    Style="{StaticResource NeutralButtonStyle}"
                                    Click="SetShowHotkeyButton_OnClick">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE3C9;"
                                               FontFamily="{StaticResource MaterialIconFontFamily}"
                                               FontSize="12"
                                               VerticalAlignment="Center" />
                                    <TextBlock x:Name="SetShowHotkeyButtonTextBlock"
                                               Margin="6,0,0,0"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <TextBlock x:Name="HotkeyConflictTextBlock"
                                       Grid.Row="3"
                                       Grid.ColumnSpan="3"
                                       Margin="0,12,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="#C2410C"
                                       FontSize="12"
                                       Visibility="Collapsed" />
                        </Grid>
                    </Border>

                    <Border Margin="0,0,0,14"
                            Padding="16"
                            CornerRadius="12"
                            Background="#FFFAFBFD"
                            BorderThickness="1"
                            BorderBrush="#FFE9EDF3">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="130" />
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="GroupHotkeysSectionTextBlock"
                                       Grid.ColumnSpan="3"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#334155" />

                            <TextBlock x:Name="GroupHotkeyTargetLabel"
                                       Grid.Row="1"
                                       Margin="0,14,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       Foreground="#4A5560" />
                            <ComboBox x:Name="GroupHotkeyComboBox"
                                      Grid.Row="1"
                                      Grid.Column="1"
                                      Grid.ColumnSpan="2"
                                      Margin="0,14,0,0"
                                      Height="40"
                                      Style="{StaticResource RoundedComboBoxStyle}"
                                      ItemContainerStyle="{StaticResource RoundedComboBoxItemStyle}"
                                      ItemTemplate="{StaticResource GroupHotkeyOptionTemplate}"
                                      VerticalContentAlignment="Center"
                                      SelectionChanged="GroupHotkeyComboBox_OnSelectionChanged" />

                            <TextBlock x:Name="GroupHideHotkeyLabel"
                                       Grid.Row="2"
                                       Margin="0,12,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       Foreground="#4A5560" />
                            <Border Grid.Row="2"
                                    Grid.Column="1"
                                    Margin="0,12,12,0"
                                    Padding="10,8"
                                    CornerRadius="8"
                                    Background="#FFFFFFFF"
                                    BorderThickness="1"
                                    BorderBrush="#FFE4E7EB">
                                <TextBlock x:Name="GroupHideHotkeyValueTextBlock"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#1F2933" />
                            </Border>
                            <Button x:Name="SetGroupHideHotkeyButton"
                                    Grid.Row="2"
                                    Grid.Column="2"
                                    Margin="0,12,0,0"
                                    Style="{StaticResource NeutralButtonStyle}"
                                    Click="SetGroupHideHotkeyButton_OnClick">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE3C9;"
                                               FontFamily="{StaticResource MaterialIconFontFamily}"
                                               FontSize="12"
                                               VerticalAlignment="Center" />
                                    <TextBlock x:Name="SetGroupHideHotkeyButtonTextBlock"
                                               Margin="6,0,0,0"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <TextBlock x:Name="GroupShowHotkeyLabel"
                                       Grid.Row="3"
                                       Margin="0,12,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       Foreground="#4A5560" />
                            <Border Grid.Row="3"
                                    Grid.Column="1"
                                    Margin="0,12,12,0"
                                    Padding="10,8"
                                    CornerRadius="8"
                                    Background="#FFFFFFFF"
                                    BorderThickness="1"
                                    BorderBrush="#FFE4E7EB">
                                <TextBlock x:Name="GroupShowHotkeyValueTextBlock"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#1F2933" />
                            </Border>
                            <Button x:Name="SetGroupShowHotkeyButton"
                                    Grid.Row="3"
                                    Grid.Column="2"
                                    Margin="0,12,0,0"
                                    Style="{StaticResource NeutralButtonStyle}"
                                    Click="SetGroupShowHotkeyButton_OnClick">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE3C9;"
                                               FontFamily="{StaticResource MaterialIconFontFamily}"
                                               FontSize="12"
                                               VerticalAlignment="Center" />
                                    <TextBlock x:Name="SetGroupShowHotkeyButtonTextBlock"
                                               Margin="6,0,0,0"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <TextBlock x:Name="GroupHotkeyConflictTextBlock"
                                       Grid.Row="4"
                                       Grid.ColumnSpan="3"
                                       Margin="0,12,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="#C2410C"
                                       FontSize="12"
                                       Visibility="Collapsed" />
                        </Grid>
                    </Border>

                    <Border Padding="16"
                            CornerRadius="12"
                            Background="#FFFAFBFD"
                            BorderThickness="1"
                            BorderBrush="#FFE9EDF3">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="130" />
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="GeneralSectionTextBlock"
                                       Grid.ColumnSpan="3"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#334155" />
                            <CheckBox x:Name="StartWithWindowsCheckBox"
                                      Grid.Row="1"
                                      Grid.ColumnSpan="3"
                                      Margin="0,14,0,0"
                                      Style="{StaticResource FlatLabeledCheckBoxStyle}" />

                            <CheckBox x:Name="MinimizeToTrayCheckBox"
                                      Grid.Row="2"
                                      Grid.ColumnSpan="3"
                                      Margin="0,10,0,0"
                                      Style="{StaticResource FlatLabeledCheckBoxStyle}" />

                            <CheckBox x:Name="RunAsAdministratorCheckBox"
                                      Grid.Row="3"
                                      Grid.ColumnSpan="3"
                                      Margin="0,10,0,0"
                                      Style="{StaticResource FlatLabeledCheckBoxStyle}" />

                            <Grid Grid.Row="4"
                                  Grid.ColumnSpan="3"
                                  Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock x:Name="AutoCheckUpdatesLabelTextBlock"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           FontSize="13"
                                           Foreground="#25313D"
                                           TextTrimming="CharacterEllipsis" />
                                <Button x:Name="CheckUpdatesButton"
                                        Grid.Column="1"
                                        Width="92"
                                        Height="30"
                                        Margin="12,0,12,0"
                                        Padding="10,6"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource NeutralButtonStyle}"
                                        Click="CheckUpdatesButton_OnClick">
                                    <TextBlock x:Name="CheckUpdatesButtonTextBlock"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </Button>
                                <CheckBox x:Name="AutoCheckUpdatesCheckBox"
                                          Grid.Column="2"
                                          HorizontalAlignment="Right"
                                          Style="{StaticResource FlatLabeledCheckBoxStyle}" />
                            </Grid>

                            <TextBlock x:Name="LanguageLabel"
                                       Grid.Row="5"
                                       VerticalAlignment="Center"
                                       Margin="0,16,0,0"
                                       FontSize="13"
                                       Foreground="#4A5560" />
                            <ComboBox x:Name="LanguageComboBox"
                                      Grid.Row="5"
                                      Grid.Column="1"
                                      Margin="0,16,12,0"
                                      Height="40"
                                      Style="{StaticResource RoundedComboBoxStyle}"
                                      ItemContainerStyle="{StaticResource RoundedComboBoxItemStyle}"
                                      VerticalContentAlignment="Center"
                                      DisplayMemberPath="DisplayText"
                                      SelectionChanged="LanguageComboBox_OnSelectionChanged" />
                            <Button x:Name="SyncLanguagesButton"
                                    Grid.Row="5"
                                    Grid.Column="2"
                                    Height="40"
                                    Margin="0,16,0,0"
                                    Style="{StaticResource NeutralButtonStyle}"
                                    Click="SyncLanguagesButton_OnClick">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE5D5;"
                                               FontFamily="{StaticResource MaterialIconFontFamily}"
                                               FontSize="12"
                                               VerticalAlignment="Center" />
                                    <TextBlock x:Name="SyncLanguagesButtonTextBlock"
                                               Margin="6,0,0,0"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>
                    </StackPanel>
                </ScrollViewer>

                <Grid Grid.Row="2" Margin="16,14,16,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button x:Name="ImportButton"
                                Width="130"
                                Height="40"
                                Margin="0,0,10,0"
                                Style="{StaticResource NeutralButtonStyle}"
                                Click="ImportButton_OnClick">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE2C6;"
                                           FontFamily="{StaticResource MaterialIconFontFamily}"
                                           FontSize="12"
                                           VerticalAlignment="Center" />
                                <TextBlock x:Name="ImportButtonTextBlock"
                                           Margin="6,0,0,0"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="ExportButton"
                                Width="130"
                                Height="40"
                                Style="{StaticResource NeutralButtonStyle}"
                                Click="ExportButton_OnClick">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE2C4;"
                                           FontFamily="{StaticResource MaterialIconFontFamily}"
                                           FontSize="12"
                                           VerticalAlignment="Center" />
                                <TextBlock x:Name="ExportButtonTextBlock"
                                           Margin="6,0,0,0"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button x:Name="CancelButton"
                                Width="130"
                                Height="40"
                                Margin="0,0,10,0"
                                Style="{StaticResource NeutralButtonStyle}"
                                Click="CancelButton_OnClick">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE5CD;"
                                           FontFamily="{StaticResource MaterialIconFontFamily}"
                                           FontSize="12"
                                           VerticalAlignment="Center" />
                                <TextBlock x:Name="CancelButtonTextBlock"
                                           Margin="6,0,0,0"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="SaveButton"
                                Width="130"
                                Height="40"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="SaveButton_OnClick">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE161;"
                                           FontFamily="{StaticResource MaterialIconFontFamily}"
                                           FontSize="12"
                                           VerticalAlignment="Center" />
                                <TextBlock x:Name="SaveButtonTextBlock"
                                           Margin="6,0,0,0"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>








