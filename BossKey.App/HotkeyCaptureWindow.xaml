<Window x:Class="BossKey.App.HotkeyCaptureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="460"
        Height="230"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource Theme.WindowBackgroundBrush}"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewKeyUp="Window_PreviewKeyUp"
        PreviewMouseDown="Window_PreviewMouseDown"
        PreviewMouseUp="Window_PreviewMouseUp">
    <Window.Resources>
        <Style x:Key="NeutralButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.ButtonNeutralBorderBrush}" />
            <Setter Property="Background" Value="{DynamicResource Theme.ButtonNeutralBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.ButtonNeutralForegroundBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="10"
                                BorderThickness="1"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Theme.ButtonNeutralHoverBackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource NeutralButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource Theme.ButtonPrimaryBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.ButtonPrimaryBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.ButtonPrimaryForegroundBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="10"
                                BorderThickness="1"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Theme.ButtonPrimaryHoverBackgroundBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Theme.ButtonPrimaryHoverBackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="InstructionTextBlock"
                   FontSize="14"
                   Foreground="{DynamicResource Theme.PrimaryTextBrush}"
                   TextWrapping="Wrap" />

        <TextBlock x:Name="CurrentLabelTextBlock"
                   Grid.Row="1"
                   Margin="0,12,0,6"
                   FontSize="13"
                   Foreground="{DynamicResource Theme.SecondaryTextBrush}" />

        <Border Grid.Row="2"
                Padding="12,10"
                CornerRadius="10"
                BorderThickness="1"
                BorderBrush="{DynamicResource Theme.BorderBrush}"
                Background="{DynamicResource Theme.SurfaceBackgroundBrush}">
            <TextBlock x:Name="HotkeyPreviewTextBlock"
                       FontSize="17"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource Theme.PrimaryTextBrush}" />
        </Border>

        <StackPanel Grid.Row="4"
                    Margin="0,16,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="ClearButton"
                    Width="100"
                    Height="40"
                    Margin="0,0,8,0"
                    Style="{StaticResource NeutralButtonStyle}"
                    Click="ClearButton_OnClick" />
            <Button x:Name="OkButton"
                    Width="100"
                    Height="40"
                    Margin="0,0,8,0"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="OkButton_OnClick"
                    />
            <Button x:Name="CancelButton"
                    Width="100"
                    Height="40"
                    Style="{StaticResource NeutralButtonStyle}"
                    Click="CancelButton_OnClick" />
        </StackPanel>
    </Grid>
</Window>
